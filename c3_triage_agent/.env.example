# Copy this file to .env and fill in your own values.

# OpenAI-compatible / Codex-style endpoint
# C3_API_KEY=your_api_key
# C3_BASE_URL can be any one of:
#   https://your-openai-compatible-endpoint
#   https://your-openai-compatible-endpoint/v1
#   https://your-openai-compatible-endpoint/v1/chat/completions
# C3_WIRE_API=chat_completions
# C3_RESPONSES_INPUT_MODE=structured
# For third-party responses endpoints that only like curl-style minimal payloads:
# C3_WIRE_API=responses
# C3_RESPONSES_INPUT_MODE=simple
# C3_DISABLE_RESPONSE_STORAGE=true
# C3_REASONING_EFFORT=high
# C3_VERBOSITY=high

# iFlow OpenAI-compatible chat/completions example
# C3_API_KEY=your_iflow_key
# C3_BASE_URL=https://apis.iflow.cn/v1
# C3_WIRE_API=chat_completions
# C3_DISABLE_RESPONSE_STORAGE=true
# C3_REASONING_EFFORT=xhigh
# C3_VERBOSITY=high

# Anthropic-style endpoint
# C3_API_KEY=your_api_key
# C3_BASE_URL can be any one of:
#   https://api.anthropic.com
#   https://api.anthropic.com/v1
#   https://api.anthropic.com/v1/messages

# Optional defaults for your own shell workflow:
# C3_DEFAULT_PROVIDER=openai_compat
# C3_DEFAULT_MODEL=your-model-name
